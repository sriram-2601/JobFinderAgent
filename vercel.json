{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/screenshots/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!api|screenshots).*\\..*)",
      "destination": "/frontend/dist/$1"
    },
    {
      "source": "/((?!api|screenshots).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
